{
  "name": "personal-cfo-electron-complete-v6",
  "private": true,
  "version": "6.0.0",
  "description": "개인 CFO 자산관리 앱 - Electron + Vite + React 전체 패키지",
  "author": "season han",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "build": "vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder",
    "clean": "rimraf dist release node_modules/.vite",
    "reinstall": "rimraf node_modules package-lock.json && npm install"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "lucide-react": "latest",
    "recharts": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "concurrently": "latest",
    "wait-on": "latest",
    "rimraf": "latest"
  },
  "build": {
    "appId": "com.personal.cfo",
    "productName": "개인 CFO 자산관리",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "개인 CFO 자산관리"
    }
  }
}
