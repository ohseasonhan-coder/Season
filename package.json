{
  "name": "personal-cfo-liked-version-electron-v7",
  "private": true,
  "version": "7.0.0",
  "description": "사용자가 선호한 App_v2_split_confirm_integrated_fixed 기반 개인 CFO 자산관리 앱",
  "author": "season han",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "build": "vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder",
    "clean": "rimraf dist release node_modules/.vite",
    "reinstall": "rimraf node_modules package-lock.json && npm install"
  },
  "dependencies": {
    "@supabase/supabase-js": "latest",
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "concurrently": "latest",
    "wait-on": "latest",
    "rimraf": "latest"
  },
  "build": {
    "appId": "com.personal.cfo.liked.version",
    "productName": "개인 CFO 자산관리",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "개인 CFO 자산관리"
    }
  }
}
